# ========================================
# SMART CAMPUS BACKEND - ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to version control
# ========================================

# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=production
PORT=3001

# ========================================
# DATABASE CONFIGURATION (Required)
# ========================================
MONGO_URI=your_mongodb_connection_string_here

# Automatic deploy seeding for test or staging environments
AUTO_SEED_TEST_DATA=false
AUTO_SEED_RESET_DATA=false
# SEED_TEST_PASSWORD=TestPass123!

# ========================================
# JWT CONFIGURATION (Required)
# ========================================
# Generate strong secrets (minimum 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_minimum_32_characters_required
JWT_EXPIRE=7d

# ========================================
# SUPER ADMIN CREDENTIALS (Required)
# ========================================
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=SecurePassword123!

# ========================================
# OPTIONAL CONFIGURATIONS
# ========================================
# JWT Refresh (optional)
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRE=30d

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=*

# Email Configuration (optional)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_email_app_password

# Cloudinary (optional)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# AI Services (optional)
# OPENAI_API_KEY=your_openai_api_key
