# ==============================================
# 🚀 SMART CAMPUS SaaS - Environment Configuration
# ==============================================

# 🖥️ SERVER CONFIGURATION
NODE_ENV=production
PORT=3001

# � DEPLOYMENT CONFIGURATION
AUTO_CREATE_ADMIN=false
DEPLOYMENT_MODE=false

# �🗄️ DATABASE CONFIGURATION
MONGO_URI=mongodb+srv://Alamin:alamin45ab@cluster0.qht4rx6.mongodb.net/smartcampus?retryWrites=true&w=majority
MONGO_DB_NAME=smartcampus

# 🔐 JWT AUTHENTICATION
JWT_SECRET=your_super_secure_jwt_secret_minimum_32_characters_long_here
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_minimum_32_characters_long_here
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# 👤 Super Admin Configuration
# IMPORTANT: Change these default credentials in production!
SUPER_ADMIN_EMAIL=admin@school.local
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_NAME=Super Administrator

# 🌐 FRONTEND CONFIGURATION
FRONTEND_URL=https://yourdomain.com
FRONTEND_URL_PROD=https://yourdomain.com

# 📧 EMAIL CONFIGURATION (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@smartcampus.com

# 📱 SMS CONFIGURATION (Optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ☁️ FILE UPLOAD CONFIGURATION (Optional)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
MAX_FILE_SIZE=10mb

# 🤖 AI CONFIGURATION (Optional)
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
AI_SERVICE_URL=http://localhost:8000

# 🔒 SECURITY CONFIGURATION
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5000
SESSION_SECRET=your_session_secret_here

# 📊 LOGGING CONFIGURATION
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# 🏢 BUSINESS CONFIGURATION
DEFAULT_SUBSCRIPTION_PLAN=trial
MAX_SCHOOLS_PER_PLAN=100
FREE_TRIAL_DAYS=30

# 🎯 FEATURE FLAGS
REQUIRE_EMAIL_VERIFICATION=false
SEND_ABSENT_SMS=false
SEND_PAYMENT_RECEIPT=true
ENABLE_AI_FEATURES=true
ENABLE_REAL_TIME_NOTIFICATIONS=true

# 📈 MONITORING CONFIGURATION
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30000

# 🚀 PERFORMANCE CONFIGURATION
CACHE_TTL=3600
MAX_CONNECTIONS=100
CONNECTION_TIMEOUT=30000
