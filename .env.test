# ========================================
# SMART CAMPUS BACKEND - ENVIRONMENT VARIABLES
# ========================================

# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=development
PORT=5000

# ========================================
# DATABASE CONFIGURATION (Required)
# ========================================
MONGO_URI=mongodb://localhost:27017/smart-campus-test

# ========================================
# JWT CONFIGURATION (Required)
# ========================================
JWT_SECRET=test_jwt_secret_minimum_32_characters_required_for_development
JWT_EXPIRE=7d

# ========================================
# SUPER ADMIN CREDENTIALS (Required)
# ========================================
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=SecurePassword123!
SUPER_ADMIN_NAME=Super Administrator
SUPER_ADMIN_PHONE=+1234567890

# ========================================
# OPTIONAL CONFIGURATIONS
# ========================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=*
BCRYPT_ROUNDS=12
